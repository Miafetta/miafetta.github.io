---
import type { MarkdownHeading } from "astro";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getCategoryUrl, getTagUrl } from "../../utils/url-utils";
import ButtonLink from "../control/ButtonLink.astro";
import ButtonTag from "../control/ButtonTag.astro";
import Categories from "./Categories.astro";
import Profile from "./Profile.astro";
import Tag from "./Tags.astro";
import TOC from "./TOC.astro";
import WidgetLayout from "./WidgetLayout.astro";
import { siteConfig } from "../../config";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
	numbering?: string;
	showToc?: boolean;
	currentCategory?: string | null;
	currentTags?: string[];
}

const className = Astro.props.class;
const {
	headings = [],
	numbering,
	showToc = false,
	currentCategory,
	currentTags,
} = Astro.props;
const isArticleSidebar =
	currentCategory !== undefined || currentTags !== undefined;
const shouldShowToc =
	siteConfig.toc.enable && (isArticleSidebar || showToc) && headings.length > 0;
const normalizedCategory =
	currentCategory && currentCategory.trim() !== ""
		? currentCategory.trim()
		: i18n(I18nKey.uncategorized);
const normalizedTags =
	currentTags?.map((tag) => tag.trim()).filter(Boolean) ?? [];
---
<div id="sidebar" class:list={[className, "w-full"]}>
    <div class="flex flex-col w-full gap-4 mb-4">
        <Profile></Profile>
    </div>
    <div id="sidebar-sticky" class="transition-all duration-700 flex flex-col w-full gap-4 top-4 sticky top-4">
        <div id="sidebar-current-meta" class="flex flex-col w-full gap-4">
            {isArticleSidebar ? (
                <>
                    <WidgetLayout
                        name={i18n(I18nKey.currentCategory)}
                        id="current-category"
                        class="onload-animation"
                        style="animation-delay: 150ms"
                    >
                        <ButtonLink
                            url={getCategoryUrl(currentCategory ?? null)}
                            label={`View all posts in the ${normalizedCategory} category`}
                        >
                            {normalizedCategory}
                        </ButtonLink>
                    </WidgetLayout>
                    <WidgetLayout
                        name={i18n(I18nKey.currentTags)}
                        id="current-tags"
                        class="onload-animation"
                        style="animation-delay: 200ms"
                    >
                        {normalizedTags.length > 0 ? (
                            <div class="flex gap-2 flex-wrap">
                                {normalizedTags.map((tag) => (
                                    <ButtonTag href={getTagUrl(tag)} label={`View all posts with the ${tag} tag`}>
                                        {tag}
                                    </ButtonTag>
                                ))}
                            </div>
                        ) : (
                            <div class="text-sm text-50 transition">{i18n(I18nKey.noTags)}</div>
                        )}
                    </WidgetLayout>
                    {shouldShowToc && (
                        <div
                            id="toc-wrapper"
                            data-sidebar-toc
                            class="hidden lg:block transition w-full items-center onload-animation"
                            style="animation-delay: 250ms"
                        >
                            <div id="toc-inner-wrapper" class="w-full h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                                <div id="toc" class="w-full h-full transition-swup-fade">
                                    <div class="h-8 w-full"></div>
                                    <TOC headings={headings} numbering={numbering}></TOC>
                                    <div class="h-8 w-full"></div>
                                </div>
                            </div>
                        </div>
                    )}
                </>
            ) : showToc ? (
                <>
                    {shouldShowToc && (
                        <div
                            id="toc-wrapper"
                            data-sidebar-toc
                            class="hidden lg:block transition w-full items-center onload-animation"
                            style="animation-delay: 150ms"
                        >
                            <div id="toc-inner-wrapper" class="w-full h-[calc(100vh_-_8rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                                <div id="toc" class="w-full h-full transition-swup-fade">
                                    <div class="h-8 w-full"></div>
                                    <TOC headings={headings} numbering={numbering}></TOC>
                                    <div class="h-8 w-full"></div>
                                </div>
                            </div>
                        </div>
                    )}
                </>
            ) : (
                <>
                    <Categories class="onload-animation" style="animation-delay: 150ms"></Categories>
                    <Tag class="onload-animation" style="animation-delay: 200ms"></Tag>
                </>
            )}
        </div>
    </div>
</div>
